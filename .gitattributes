# Normalize line endings
* text=auto

# Force LF for common text files
*.ts text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sh text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.svg binary
*.ico binary
*.zip binary
*.gz binary
.DS_Store binary

# Package lock files are JSON
package-lock.json text eol=lf
