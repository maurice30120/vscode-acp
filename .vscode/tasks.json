// See https://go.microsoft.com/fwlink/?LinkId=733558
// for the documentation about the tasks.json format
{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "npm: watch",
			"type": "npm",
			"script": "watch",
			"problemMatcher": [
				{
					"owner": "custom",
					"fileLocation": "absolute",
					"pattern": [
						{
							"regexp": "^(.*):(\\d+):(\\d+):\\s+(error|warning):\\s+(.*)$",
							"file": 1,
							"line": 2,
							"column": 3,
							"severity": 4,
							"message": 5
						}
					],
					"background": {
						"activeOnStart": true,
						"beginsPattern": ".",
						"endsPattern": "(built in [0-9]+ms|watching for file changes|Watching for changes|Build success in [0-9]+ms|DTS.*Build success)"
					}
				}
			],
			"isBackground": true,
			"presentation": {
				"reveal": "never"
			},
			"group": {
				"kind": "build",
				"isDefault": true
			}
		},
		{
			"type": "npm",
			"script": "compile-tests",
			"problemMatcher": [
				"$tsc"
			],
			"group": "build",
			"label": "npm: compile-tests"
		}
	]
}
